# База данных: postgres (рекомендуется для продакшена) или sqlite
# Для продакшена и масштабирования рекомендуется PostgreSQL.
# Для локальной разработки можно использовать SQLite: DB_TYPE=sqlite (база создаётся в data/doorphone.sqlite).
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=doorphone

# JWT для авторизации API
# Срок жизни access token (например: 15m, 1h, 24h). По умолчанию: 15m
JWT_EXPIRES=15m
JWT_SECRET=your-secret-key

# AES-256 key for device credentials (32 chars). If unset, dev default is used.
# CREDENTIALS_ENCRYPTION_KEY=

# Порт backend API
PORT=3000

# Разрешённые origins для WebSocket (через запятую). В production ДОЛЖНО быть задано.
# Пример: http://localhost:8100,http://localhost:3000
WS_ALLOWED_ORIGINS=http://localhost:8100,http://localhost:3000

# Разрешённые origins для CORS (через запятую). В production ДОЛЖНО быть задано.
# Пример: http://localhost:8100,http://localhost:3000,https://app.grgmobile.com
CORS_ORIGINS=http://localhost:8100,http://localhost:3000

# FCM для push-уведомлений (входящий звонок). Опционально.
# Вариант 1: JSON сервисного аккаунта в одной строке (без переносов)
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Вариант 2: путь к файлу ключа
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/serviceAccountKey.json

# Секрет для вебхуков от панелей (заголовок X-Webhook-Secret). Обязателен для приёма событий входящего звонка.
WEBHOOK_SECRET=your-webhook-secret

# Rate limit для webhooks (запросов в минуту с одного IP)
WEBHOOK_RATE_LIMIT_MAX=100

# go2rtc media server (optional — enables HLS proxy for WAN access)
# Internal URL used by backend to register streams (Docker internal or localhost)
GO2RTC_URL=http://localhost:1984
# Public URL returned to Flutter clients for HLS playback
# In production: set to your public domain, e.g. https://media.your-domain.com
GO2RTC_PUBLIC_URL=http://localhost:1984
